# SearchProbe Configuration
# Copy this file to .env and fill in your API keys

# Search Provider API Keys
SEARCHPROBE_EXA_API_KEY=your-exa-api-key
SEARCHPROBE_TAVILY_API_KEY=your-tavily-api-key
SEARCHPROBE_BRAVE_API_KEY=your-brave-api-key
SEARCHPROBE_SERPAPI_API_KEY=your-serpapi-api-key

# LLM API Keys (for query generation and evaluation)
SEARCHPROBE_ANTHROPIC_API_KEY=your-anthropic-api-key
SEARCHPROBE_OPENAI_API_KEY=your-openai-api-key

# Optional Settings
SEARCHPROBE_DATABASE_PATH=searchprobe.db
SEARCHPROBE_DEFAULT_NUM_RESULTS=10
SEARCHPROBE_MAX_CONCURRENT_REQUESTS=5
SEARCHPROBE_BUDGET_LIMIT_USD=10.0
SEARCHPROBE_JUDGE_MODEL=claude-sonnet-4-20250514
SEARCHPROBE_GENERATION_MODEL=claude-sonnet-4-20250514
